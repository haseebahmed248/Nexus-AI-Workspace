generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model test {
  id      Int @id @default(autoincrement())
  counter Int
}

model User {
  id        Int      @id @default(autoincrement())
  userId    String
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model passwordReset {
  id        Int      @id @default(autoincrement())
  userId    String
  token     String
  expiresAt DateTime
}
